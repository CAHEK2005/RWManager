# PostgreSQL
POSTGRES_USER=rwm
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=rwmanager

# Backend JWT (generate: openssl rand -hex 32)
JWT_SECRET=change_me_64_char_hex_string

# Initial admin credentials (used only on first startup)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_strong_password

# Secrets encryption key — 32-byte hex (generate: openssl rand -hex 32)
SECRET_ENCRYPTION_KEY=change_me_64_char_hex_string

# CORS — comma-separated allowed origins for the frontend
CORS_ORIGIN=http://localhost:5173

# Allow Remnawave panel URLs that resolve to private IPs, e.g. 10.x/192.168.x.
# Set to true only for your trusted internal/self-hosted panel.
RWM_ALLOW_PRIVATE_REMNAWAVE=false

# Frontend port (default 80)
# PORT=80
